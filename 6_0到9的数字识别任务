    {
      "cell_type": "code",
      "source": [
        "#create dataset\n",
        "train_loader=DataLoader(train_dataset,batch_size=32,shuffle=True)\n",
        "test_loader=DataLoader(test_dataset,batch_size=1000,shuffle=False)"
      ],
      "metadata": {
        "id": "0uzmP1tPjkqi"
      },
      "execution_count": 17,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#creat NN\n",
        "class image_classifier(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.flatten=nn.Flatten()\n",
        "        self.layers=nn.Sequential(\n",
        "            nn.Linear(28*28,128),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(128,10),\n",
        "        )\n",
        "\n",
        "    def forward(self,x):\n",
        "        x=self.flatten(x)\n",
        "        x=self.layers(x)\n",
        "        return x"
      ],
      "metadata": {
        "id": "RxVfK91mshY9"
      },
      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#device and optimizer\n",
        "device=torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "model=image_classifier().to(device)\n",
        "optimizer=optim.Adam(model.parameters(),lr=0.001)"
      ],
      "metadata": {
        "id": "1L6zMSotseey"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cf4469f6"
      },
      "source": [
        "# 定义损失函数\n",
        "loss_fn = nn.CrossEntropyLoss()"
      ],
      "execution_count": 16,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#创建一个函数进行一个epoch的计算\n",
        "def train_epoch(model,train_loader,optimizer,loss_fn,device):\n",
        "    model.train()\n",
        "    running_loss = 0.0 # Corrected initialization for running loss\n",
        "    correct = 0\n",
        "    total = 0\n",
        "\n",
        "    for batch_idx,(data,target) in enumerate(train_loader):\n",
        "        data,target=data.to(device),target.to(device)\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "        output=model(data)\n",
        "        loss=loss_fn(output,target)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "        # Accumulate loss and correct predictions for the entire epoch\n",
        "        running_loss += loss.item() * data.size(0) # Sum of loss for each sample in the batch\n",
        "        _, predicted = torch.max(output.data, 1)\n",
        "        total += target.size(0)\n",
        "        correct += (predicted == target).sum().item()\n",
        "\n",
        "    # Calculate average loss and accuracy for the epoch\n",
        "    epoch_loss = running_loss / total\n",
        "    epoch_accuracy = 100 * correct / total\n",
        "\n",
        "    return epoch_loss, epoch_accuracy"
      ],
      "metadata": {
        "id": "Ci6qo3A6zbeX"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#在测试集上评估\n",
        "def evaluate(model,test_loader,device):\n",
        "    model.eval()\n",
        "    correct=0\n",
        "    total=0\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for data,target in test_loader:\n",
        "          data,target=data.to(device),target.to(device)\n",
        "          outputs=model(data)\n",
        "          _,predicted=torch.max(outputs.data,1)\n",
        "          total+=target.size(0)\n",
        "          correct+=(predicted==target).sum().item()\n",
        "    return 100.*correct/total"
      ],
      "metadata": {
        "id": "ys4gGVg6gokF"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#training loop\n",
        "num_epoch=100\n",
        "\n",
        "train_losses = []\n",
        "train_accuracies = []\n",
        "test_accuracies = []\n",
        "\n",
        "for epoch in range(num_epoch):\n",
        "    print(f\"Epoch {epoch+1}/{num_epoch}\")\n",
        "\n",
        "    # Get training loss and accuracy from the modified train_epoch function\n",
        "    train_loss, train_acc = train_epoch(model,train_loader,optimizer,loss_fn,device)\n",
        "    test_acc = evaluate(model,test_loader,device)\n",
        "\n",
        "    train_losses.append(train_loss)\n",
        "    train_accuracies.append(train_acc)\n",
        "    test_accuracies.append(test_acc)\n",
        "\n",
        "    print(f\"Train Loss: {train_loss:.4f}, Train Acc: {train_acc:.2f}%, Test Acc: {test_acc:.2f}%\")"
      ],
